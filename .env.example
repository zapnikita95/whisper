# Скопируй в `whisper/.env` и подставь значения. Файл `.env` в git не коммитится.

# --- Groq через Railway-прокси (когда api.groq.com с твоей сети не открывается) ---
WHISPER_GROQ_PROXY_URL=https://whisper-groq-proxy-production.up.railway.app
# Совпадает с PROXY_SHARED_SECRET в Railway → Variables (сервис groq_proxy):
WHISPER_GROQ_PROXY_SECRET=

# Ключ Groq: локально в .env или только на прокси (GROQ_API_KEY в Railway) — см. groq_proxy/README.md
# GROQ_API_KEY=

# --- Где искать .env клиентами ---
# Mac (whisper-client-mac): рядом с репо `whisper/.env`, внутри .app Resources, или
#   ~/Library/Application Support/WhisperClient/.env (перекрывает предыдущие).
# Windows (whisper_hotkey_tray): рядом со скриптом/exe, родители каталога до 16 уровней, или
#   %APPDATA%\WhisperClient\.env
